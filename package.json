{
  "name": "durag",
  "version": "0.3.0",
  "description": "where patterns emerge. Multi-source pattern detection for JavaScript.",
  "type": "module",
  "main": "dist/durag.umd.js",
  "module": "dist/durag.esm.js",
  "exports": {
    ".": {
      "import": "./dist/durag.esm.js",
      "require": "./dist/durag.umd.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "data",
    "pattern-recognition",
    "csv",
    "merge",
    "analytics",
    "admin-panel"
  ],
  "author": "Atlantium Inc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AtlantiumInc/durag.git"
  },
  "homepage": "https://github.com/AtlantiumInc/durag",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "rollup": "^4.0.0"
  }
}
